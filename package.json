{
    "name": "fsds-academy-back-end",
    "version": "0.1.0",
    "private": true,
    "main": "dist/server.js",
    "scripts": {
        "build": "npm i && tsc -p tsconfig.build.json",
        "start": "node --max-old-space-size=8192 dist/server.js",
        "dev": "ts-node-dev --max-old-space-size=8192 --respawn --transpile-only --ignore-watch node_modules src/server.ts",
        "watch": "nodemon --watch src --ext ts --exec \"ts-node src/server.ts\"",
        "lint": "eslint './src/**/*.{ts,js}' --fix",
        "format": "prettier --write './**/*.{ts,js,json,md}'",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage"
    },
    "engines": {
        "node": ">=14"
    },
    "dependencies": {
        "@google/generative-ai": "^0.24.1",
        "bcrypt": "^6.0.0",
        "bcryptjs": "^2.4.3",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.3",
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^16.6.1",
        "express": "^4.18.2",
        "helmet": "^6.0.1",
        "jsonwebtoken": "^9.0.0",
        "mongoose": "^7.5.0",
        "morgan": "^1.10.0",
        "reflect-metadata": "^0.1.13",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/compression": "^1.8.1",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.25",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.10",
        "@types/node": "^20.19.23",
        "@types/uuid": "^10.0.0",
        "@typescript-eslint/eslint-plugin": "^7.11.0",
        "@typescript-eslint/parser": "^7.11.0",
        "eslint": "^8.48.0",
        "eslint-config-prettier": "^9.0.0",
        "jest": "^30.2.0",
        "nodemon": "^3.0.1",
        "prettier": "^3.0.0",
        "ts-jest": "^29.4.5",
        "ts-node": "^10.9.1",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.9.0"
    }
}
